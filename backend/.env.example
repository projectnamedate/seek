# Server Configuration
PORT=3001
NODE_ENV=production  # 'development' only allowed when SOLANA_NETWORK != mainnet-beta

# Solana Configuration
# Mainnet RPC: https://api.mainnet-beta.solana.com (rate-limited) or Helius/QuickNode/Triton
# Devnet RPC:  https://api.devnet.solana.com
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
SOLANA_NETWORK=mainnet-beta

# COLD authority: signs admin ops (withdraw_treasury, fund_house, set_hot_authority,
# propose_authority_transfer, resolve_dispute). On mainnet this should be a
# Ledger-backed or KMS-signed keypair. Never commit to git.
AUTHORITY_PRIVATE_KEY=your_base58_private_key_here

# HOT authority: signs ONLY reveal_mission + propose_resolution. Backend-held.
# Compromise is contained (cannot drain treasury or rotate authority).
# REQUIRED on mainnet-beta.
HOT_AUTHORITY_PRIVATE_KEY=your_hot_base58_private_key_here

# Program IDs
SEEK_PROGRAM_ID=DqsCXFjgLp4UDZgMQE6nvEHe7yiRNJsVYFv21JSbd73v
# Mainnet SKR (official Solana Mobile token, 6 decimals)
# Devnet test mint (9 decimals): u3BkoKjVYYPt24Dto1VPwAzqeQg9ffaxnCVhTAYbAFF
SKR_MINT=SKRbvo6Gf7GondiT3BbTfuRDPqLWei4j2Qy2NPGZhW3

# Anthropic (Claude API) - Get your key at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-your-api-key-here

# Validation Settings
MAX_PHOTO_AGE_SECONDS=300
MIN_CONFIDENCE_SCORE=0.7

# SGT verification (optional — lowers confidence threshold for Seeker owners)
HELIUS_API_KEY=
SGT_BONUS_CONFIDENCE_REDUCTION=0.05

# Sentry (optional — omit to disable error tracking)
SENTRY_DSN=

# Redis (optional during dev — REQUIRED on mainnet for state persistence + scale)
# Recommended: Upstash Redis (serverless, free tier covers launch volume).
REDIS_URL=
